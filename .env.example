# Example environment variables for Promptise
# Copy this file to .env and fill in your values

# ============================================================================
# Required: OpenAI API Key OR any other supported LLM API key (Anthropic, etc.)
# ============================================================================
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# Optional: Anthropic API Key (for Claude models)
# ============================================================================
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# Optional: Model Configuration
# ============================================================================
# Default model to use (openai:gpt-5-mini, openai:gpt-4, etc.)
# DEFAULT_MODEL=openai:gpt-5-mini

# ============================================================================
# Optional: Orchestration Configuration
# ============================================================================
# Redis URL for distributed features (RedLock, message broker)
# REDIS_URL=redis://localhost:6379

# Etcd URLs for distributed registry
# ETCD_URLS=http://localhost:2379

# Discovery protocol (registry, mdns, gossip, multicast)
# DISCOVERY_PROTOCOL=registry

# ============================================================================
# Optional: Sandbox Configuration
# ============================================================================
# Sandbox mode (docker, e2b)
# SANDBOX_MODE=docker

# E2B API key (if using E2B sandbox)
# E2B_API_KEY=your-e2b-api-key-here

# ============================================================================
# Optional: Security Configuration
# ============================================================================
# JWT secret key for agent authentication
# JWT_SECRET_KEY=your-secret-key-here

# ============================================================================
# Optional: Monitoring Configuration
# ============================================================================
# Enable metrics collection
# ENABLE_METRICS=true

# Prometheus metrics port
# METRICS_PORT=9090

# Enable structured logging
# ENABLE_STRUCTURED_LOGGING=true

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================================================
# Optional: Development Settings
# ============================================================================
# Debug mode
# DEBUG=false

# Development mode
# DEV_MODE=true
